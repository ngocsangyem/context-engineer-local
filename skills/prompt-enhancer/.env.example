# Prompt Enhancer — External AI Provider Configuration
# Copy this file to .env and fill in your values.
# This .env works from EITHER location:
#   skills/prompt-enhancer/.env
#   .claude/skills/prompt-enhancer/.env

# Provider: gemini | ollama | openai | none (default: none)
PROMPT_ENHANCER_PROVIDER=none

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (local, no API key needed) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- OpenAI-compatible (vLLM, LM Studio, Groq, Together) ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
